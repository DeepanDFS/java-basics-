// opertaor distance formula---------------------------------------------------------------------------------------------------------------------------------------------------------------------

import java.util.*;

public class Solution 
{

    public static void main(String[] args)
    {
        Scanner sc=new Scanner(System.in);
        int x1=sc.nextInt();
        int y1=sc.nextInt();
        int x2=sc.nextInt();
        int y2=sc.nextInt();
        int dis=((x2-x1)*(x2-x1))+((y2-y1)*(y2-y1));
        System.out.println("The computed distance value is "+dis);
    }
}
